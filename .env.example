# pgAdmin image and localhost-only host port
PGADMIN_IMAGE=dpage/pgadmin4:9
PGADMIN_HOST_BIND_ADDRESS=127.0.0.1
PGADMIN_HOST_PORT=5050

# Initial pgAdmin login
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=replace-with-a-long-random-password

# Optional pgAdmin hardening and UX
PGADMIN_DISABLE_POSTFIX=true
PGADMIN_CONFIG_ENHANCED_COOKIE_PROTECTION=True
